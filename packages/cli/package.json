{
  "name": "auto-gdd",
  "version": "0.1.0",
  "description": "CLI for generating Game Design Documents with local AI — free, offline, Obsidian-ready",
  "license": "MIT",
  "keywords": [
    "game design document",
    "gdd",
    "ai",
    "ollama",
    "obsidian",
    "game dev",
    "local ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/auto-gdd/auto-gdd",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/auto-gdd/auto-gdd#readme",
  "bugs": {
    "url": "https://github.com/auto-gdd/auto-gdd/issues"
  },
  "type": "module",
  "bin": {
    "auto-gdd": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
