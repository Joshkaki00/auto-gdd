{
  "name": "auto-gdd",
  "version": "0.1.0",
  "description": "CLI for generating Game Design Documents with local AI — free, offline, Obsidian-ready",
  "license": "MIT",
  "keywords": ["game design document", "gdd", "ai", "ollama", "obsidian", "game dev", "local ai"],
  "repository": { "type": "git", "url": "https://github.com/auto-gdd/auto-gdd" },
  "type": "module",
  "bin": {
