    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@auto-gdd/core": "*",
    "commander": "^12.0.0",
    "inquirer": "^10.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0"
  }
}
