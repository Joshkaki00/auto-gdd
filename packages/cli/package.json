    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@auto-gdd/core": "*",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "inquirer": "^14.0.2",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0"
