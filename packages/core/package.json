  "description": "Core GDD engine for auto-gdd: Ollama client, RAG pipeline, workspace detector, codebase scanner, GDD assembler",
  "license": "MIT",
  "keywords": [
    "game design document",
    "gdd",
    "ollama",
    "rag",
    "local ai",
    "game dev"
  ],
  "repository": {
