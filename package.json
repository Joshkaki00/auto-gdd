{
  "name": "auto-gdd",
  "version": "0.1.0",
  "private": true,
  "description": "Local AI Game Design Document generator — free, offline, Obsidian-ready",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build --workspace=packages/core",
    "build:cli": "npm run build --workspace=packages/cli",
    "build:mcp": "npm run build --workspace=packages/mcp",
    "build:vscode": "npm run build --workspace=packages/vscode",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "dev:mcp": "npm run dev --workspace=packages/mcp",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "lint": "eslint \"packages/**/src/**/*.ts\"",
    "lint:fix": "eslint \"packages/**/src/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "prepare": "husky",
    "clean": "npm run clean --workspaces --if-present",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "husky": "^9.1.7",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
