{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm install*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(node packages/cli/dist/index.js*)",
      "Bash(node packages/mcp/dist/index.js*)",
      "Bash(npx auto-gdd*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git stash*)",
      "Bash(git checkout *)",
      "Bash(git branch*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(npm publish*)"
    ],
    "deny": [
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(sudo*)",
      "Bash(npm install*openai*)",
      "Bash(npm install*anthropic*)",
      "Bash(npm install*groq*)",
      "Bash(npm install*@google/generative*)",
      "Bash(npm install*cohere*)",
      "Bash(npm install*mistralai*)",
      "Bash(npm install*replicate*)",
      "Bash(npm install*together-ai*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const f=process.env.CLAUDE_TOOL_FILE||''; const path=require('path'); if(!f.endsWith('.ts')) process.exit(0); const pkg=f.replace(/\\\\\\\\/g,'/').match(/packages\\/([^\\/]+)\\//)?.[1]; const cmd=pkg?`npm run build --workspace=packages/${pkg}`:'npm run build'; const {execSync}=require('child_process'); try{execSync(cmd,{stdio:'pipe',timeout:90000}); console.log('✓ Build clean after editing '+path.basename(f));}catch(e){const out=(e.stdout+e.stderr).toString().split('\\n').filter(l=>l.includes('error')).slice(0,10).join('\\n'); console.log('⚠️ Build errors in '+path.basename(f)+':\\n'+out);}\""
          }
        ]
      }
    ]
  }
}
